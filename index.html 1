						list-style:none;
						gap:25px;
						}

						nav a{
						color:white;
						text-decoration:none;
						}

						.hero{
						min-height:100vh;
						display:flex;
						align-items:center;
						justify-content:center;
						text-align:center;
						padding:40px;
						}

						.hero-content{
						max-width:900px;
						}

						.tag{
						display:inline-block;
						border:1px solid var(--accent);
						color:var(--accent);
						padding:10px 20px;
						border-radius:50px;
						margin-bottom:20px;
						}

						.hero h1{
						font-size:clamp(3rem,8vw,6rem);
						margin-bottom:20px;
						}

						.hero p{
						color:var(--gray);
						font-size:1.2rem;
						margin-bottom:30px;
						}

						.btn{
						display:inline-block;
						padding:15px 30px;
						background:var(--accent);
						color:black;
						text-decoration:none;
						border-radius:10px;
						font-weight:bold;
						}

						section{
						max-width:1200px;
						margin:auto;
						padding:100px 20px;
						}

						.section-title{
						text-align:center;
						font-size:3rem;
						margin-bottom:60px;
						}

						.about{
						text-align:center;
						color:var(--gray);
						line-height:1.8;
						max-width:800px;
						margin:auto;
						}

						.skills{
						display:grid;
						grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
						gap:20px;
						}

						.skill{
						background:var(--card);
						padding:30px;
						border-radius:20px;
						text-align:center;
						transition:.3s;
						}

						.skill:hover{
						transform:translateY(-10px);
						}

						.skill i{
						font-size:3rem;
						color:var(--accent);
						margin-bottom:15px;
						}

						.projects{
						display:grid;
						grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
						gap:25px;
						}

						.card{
						background:var(--card);
						border-radius:20px;
						overflow:hidden;
						transition:.3s;
						}

						.card:hover{
						transform:translateY(-10px);
						}

						.card img{
						width:100%;
						height:220px;
						object-fit:cover;
						}

						.card-content{
						padding:20px;
						}

						.card-content h3{
						margin-bottom:10px;
						}

						.card-content p{
						color:var(--gray);
						margin-bottom:15px;
						}

						.contact{
						max-width:700px;
						margin:auto;
						}

						input,
						textarea{
						width:100%;
						padding:15px;
						margin-bottom:15px;
						border:none;
						border-radius:10px;
						background:#111827;
						color:white;
						}

						button{
						width:100%;
						padding:15px;
						border:none;
						border-radius:10px;
						background:var(--accent);
						font-weight:bold;
						cursor:pointer;
						}

						footer{
						text-align:center;
						padding:40px;
						color:var(--gray);
						}

						.socials{
						display:flex;
						justify-content:center;
						gap:20px;
						margin-top:20px;
						}

						.socials a{
						color:var(--accent);
						font-size:1.5rem;
						}

						.glow{
						position:fixed;
						width:400px;
						height:400px;
						background:var(--accent);
						filter:blur(200px);
						opacity:.15;
						pointer-events:none;
						}

						@media(max-width:768px){

