					<style>

						:root{
						--bg:#050816;
						--card:#0f172a;
						--accent:#00d4ff;
						--text:#ffffff;
						--gray:#94a3b8;
						}

						*{
						margin:0;
						padding:0;
						box-sizing:border-box;
						font-family:Inter,Segoe UI,sans-serif;
						}

						html{
						scroll-behavior:smooth;
						}

						body{
						background:var(--bg);
						color:var(--text);
						}

						header{
						position:fixed;
						width:100%;
						top:0;
						z-index:1000;
						backdrop-filter:blur(15px);
						background:rgba(5,8,22,.7);
